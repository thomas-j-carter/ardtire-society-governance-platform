{
  "name": "ardtire-governance-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.11.1",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "format": "pnpm -r --if-present format",
    "clean": "pnpm -r --if-present clean",
    "check": "pnpm build && pnpm typecheck && pnpm test",
    "prisma:generate": "pnpm --filter @ardtire/prisma generate",
    "prisma:format": "pnpm --filter @ardtire/prisma format",
    "prisma:validate": "pnpm --filter @ardtire/prisma validate",
    "prisma:studio": "pnpm --filter @ardtire/prisma studio",
    "db:migrate:dev": "pnpm --filter @ardtire/prisma migrate:dev",
    "db:migrate:deploy": "pnpm --filter @ardtire/prisma migrate:deploy"
  },
  "devDependencies": {
    "@types/node": "^20.19.13",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
