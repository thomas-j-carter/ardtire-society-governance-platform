{
  "name": "@ardtire/docs-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Repository inventory and documentation tooling",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "docs-engine": "./dist/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  }
}
